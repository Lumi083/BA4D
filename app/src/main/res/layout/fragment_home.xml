<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/description" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/risk_warning"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="点个Star吧！拜托了！"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@android:color/holo_red_dark" />

        <Button
            android:id="@+id/startOverlayButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/start_overlay" />

        <Button
            android:id="@+id/stopOverlayButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/stop_overlay" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/overlayPermissionStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/overlay_permission_missing"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/openOverlayPermissionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/open_overlay_permission" />

                <TextView
                    android:id="@+id/shizukuPermissionStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/shizuku_permission_missing"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/openShizukuPermissionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/open_shizuku_permission" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/downloadShizukuButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/download_shizuku" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/baspark_config_title"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/baspark_config_description"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/adaptiveColorSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="自适应颜色（亮处变白，需要录屏权限）" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/scale_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/scaleInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="@string/speed_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/speedInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="@string/main_color_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/colorInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/main_color_presets"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="start"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mainColorPreset0"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="10dp"
                        android:minWidth="44dp"
                        android:minHeight="44dp"
                        android:text=""
                        app:backgroundTint="#23CFFF"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mainColorPreset1"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="10dp"
                        android:minWidth="44dp"
                        android:minHeight="44dp"
                        android:text=""
                        app:backgroundTint="#7A00FF"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mainColorPreset2"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="10dp"
                        android:minWidth="44dp"
                        android:minHeight="44dp"
                        android:text=""
                        app:backgroundTint="#FF3C3C"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mainColorPreset3"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="10dp"
                        android:minWidth="44dp"
                        android:minHeight="44dp"
                        android:text=""
                        app:backgroundTint="#57A7FF"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mainColorPreset4"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:minWidth="44dp"
                        android:minHeight="44dp"
                        android:text=""
                        app:backgroundTint="#FFA228"
                        app:cornerRadius="12dp" />
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="拖尾颜色">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/trailColorInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="拖尾颜色预设"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="start"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/trailColorPreset0"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="10dp"
                        android:minWidth="44dp"
                        android:minHeight="44dp"
                        android:text=""
                        app:backgroundTint="#00C8FF"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/trailColorPreset1"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="10dp"
                        android:minWidth="44dp"
                        android:minHeight="44dp"
                        android:text=""
                        app:backgroundTint="#9664FF"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/trailColorPreset2"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="10dp"
                        android:minWidth="44dp"
                        android:minHeight="44dp"
                        android:text=""
                        app:backgroundTint="#FF6464"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/trailColorPreset3"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="10dp"
                        android:minWidth="44dp"
                        android:minHeight="44dp"
                        android:text=""
                        app:backgroundTint="#64C8FF"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/trailColorPreset4"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:minWidth="44dp"
                        android:minHeight="44dp"
                        android:text=""
                        app:backgroundTint="#FFC864"
                        app:cornerRadius="12dp" />
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="@string/max_trail_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/maxTrailInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="@string/opacity_mul_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/opacityMulInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="@string/fps_limit_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/fpsLimitInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="@string/spark_rate_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/sparkRateInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/resetConfigButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/reset_baspark_config" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
