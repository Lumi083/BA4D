<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="坐标校准工具"
        android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="说明：\n1. 先在主页启动悬浮窗\n2. 使用数字滚轮调整 X 和 Y 缩放系数。\n动画偏右：调小 X。动画偏下：调小 Y。\n动画偏左：调大 X。动画偏上：调大 Y。\n3. 在页面底部点击测试。\n4. 自动保存，退出即可。"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:lineSpacingMultiplier="1.2"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="精度："
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/precisionCoarseButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="粗 (10)"
            android:textSize="12sp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <Button
            android:id="@+id/precisionMediumButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="中 (250)"
            android:textSize="12sp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <Button
            android:id="@+id/precisionFineButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="细 (10k)"
            android:textSize="12sp"
            style="@style/Widget.Material3.Button.OutlinedButton" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="X 系数"
                android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                android:layout_marginBottom="8dp" />

            <NumberPicker
                android:id="@+id/scaleXPicker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Y 系数"
                android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                android:layout_marginBottom="8dp" />

            <NumberPicker
                android:id="@+id/scaleYPicker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/infoTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="当前系数: X=1.00000, Y=1.00000"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:fontFamily="monospace"
        android:background="#20000000"
        android:padding="12dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp">

        <com.miradesktop.ba4d.CalibrationCanvasView
            android:id="@+id/calibrationCanvas"
            android:layout_width="400dp"
            android:layout_height="400dp"
            android:layout_gravity="center"
            android:background="#10000000" />
    </FrameLayout>

</LinearLayout>
